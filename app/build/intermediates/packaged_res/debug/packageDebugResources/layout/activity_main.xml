<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Camera preview will be added here (GLSurfaceView) -->
    <FrameLayout
        android:id="@+id/preview_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/stats_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/action_bar" />

    <!-- Right action bar — FABs (72dp, glove-friendly) -->
    <LinearLayout
        android:id="@+id/action_bar"
        android:layout_width="88dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/stats_bar"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Settings FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_settings"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_margin="6dp"
            android:contentDescription="Settings"
            android:src="@android:drawable/ic_menu_preferences"
            app:fabCustomSize="72dp"
            app:backgroundTint="#2D2D2D" />

        <!-- Record FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_record"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_margin="6dp"
            android:contentDescription="Record"
            android:src="@android:drawable/ic_media_play"
            app:fabCustomSize="72dp"
            app:backgroundTint="#1E88E5" />

        <!-- White/Black hot toggle FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_palette"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_margin="6dp"
            android:contentDescription="Toggle White/Black hot"
            android:src="@android:drawable/ic_menu_view"
            app:fabCustomSize="72dp"
            app:backgroundTint="#2D2D2D" />

    </LinearLayout>

    <!-- Bottom stats bar -->
    <TextView
        android:id="@+id/stats_bar"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:background="#CC000000"
        android:fontFamily="monospace"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="FPS: --  DROP: 0  USB: --  YUV422"
        android:textColor="#B3FFFFFF"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Status text (shown when no camera) -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting for USB camera..."
        android:textColor="#B3FFFFFF"
        android:textSize="18sp"
        app:layout_constraintTop_toTopOf="@id/preview_container"
        app:layout_constraintBottom_toBottomOf="@id/preview_container"
        app:layout_constraintStart_toStartOf="@id/preview_container"
        app:layout_constraintEnd_toEndOf="@id/preview_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
